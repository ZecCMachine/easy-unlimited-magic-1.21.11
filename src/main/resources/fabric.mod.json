	"description": "An extension to Easy Magic by Fuzs which adds compatibility for mods adding more powerful bookshelves.",
	"authors": [
		"Z_cC"
	],
	"contact": {
		"sources": "https://github.com/ZecCMachine/easy-unlimited-magic-1.21.11"
	},
	"license": "CC0-1.0",
	"icon": "assets/easy-unlimited-magic/icon.png",
	"environment": "*",
